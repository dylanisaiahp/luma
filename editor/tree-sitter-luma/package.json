{
  "name": "tree-sitter-luma",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Luma programming language",
  "main": "bindings/node",
  "keywords": ["tree-sitter", "luma", "parser"],
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "node-gyp-build": "^4.6.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.26.7"
  },
  "scripts": {
    "build": "tree-sitter generate && node-gyp build",
    "generate": "tree-sitter generate",
    "test": "tree-sitter test"
  },
  "tree-sitter": [
    {
      "scope": "source.luma",
      "file-types": ["lm"],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm"
    }
  ]
}
