struct Point {
    int x;
    int y;

    int sum() {
        return x + y;
    }
}

struct Person {
    string name;
    int age;
    bool active;
}

void main() {
    Point p = Point(x: 3, y: 7);
    print(p.x);
    print(p.y);
    print(p.sum());

    Person bob = Person(name: "Bob", age: 30, active: true);
    print(bob.name);
    print(bob.age);
    print(bob.active);
}
