void main() {
    list(int) nums = (1, 2, 3, 4, 5);
    print(nums.len());
    print(nums.get(0));
    print(nums.contains(3));
    print(nums.where(4));

    list(int) sorted = nums.reverse();
    print(sorted);

    table(string, int) scores = ("Dylan": 100, "Alex": 95);
    print(scores.len());
    print(scores.get("Dylan"));
    print(scores.has("Alex"));

    for item in nums {
        print(item);
    }

    for (key, value) in scores {
        print(key);
        print(value);
    }
}
