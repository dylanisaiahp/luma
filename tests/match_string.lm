void main() {
    string cmd = "help";

    match cmd {
        "help":
            print("showing help");
        ("quit", "exit", "q"):
            print("goodbye");
        else:
            print("unknown command");
    }

    string lang = "luma";
    match lang {
        ("rust", "luma"):
            print("good choice");
        "python":
            print("not bad");
        else:
            print("never heard of it");
    }
}
