# recursion.lm

# Test 1: simple recursion (side effects only)
void count(int n) {
    print(n);

    if (n == 0) {
        return;
    }

    count(n - 1);
}

# Test 2: recursion with return propagation
int sum_down(int n) {
    if (n == 0) {
        return 0;
    }

    return n + sum_down(n - 1);
}

# Test 3: fibonacci (two recursive calls in expression)
int fib(int n) {
    if (n <= 1) {
        return n;
    }

    return fib(n - 1) + fib(n - 2);
}

void main() {
    print("Test 1: count");
    count(5);

    print("Test 2: sum_down(5)");
    print(sum_down(5));  # expected: 15

    print("Test 3: fib(5)");
    print(fib(5));       # expected: 5
}
