void main() {
    # write and read
    file("tests/io/test_output.txt").write("Hello from Luma!");
    string content = file("tests/io/test_output.txt").read();
    print(content);

    # exists
    print(file("tests/io/test_output.txt").exists());
    print(file("tests/io/nonexistent.txt").exists());

    # append
    file("tests/io/test_output.txt").append(" More text!");
    string appended = file("tests/io/test_output.txt").read();
    print(appended);
}
