void main() {
    # Test basic TOML parsing
    file("tests/io/test_config.toml").write("name = \"Luma\"\nversion = \"1.0\"");
    string toml_str = file("tests/io/test_config.toml").read();
    table(string, string) config = toml(toml_str).parse();
    print(config.get("name"));
    print(config.get("version"));
    
    # Test TOML encoding - pass table directly to toml() to encode
    table(string, string) new_config = ("database": "postgres", "port": "5432", "debug": "false");
    string encoded = toml(new_config);
    print(encoded);
    
    print("TOML tests passed!");
}