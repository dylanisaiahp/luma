worry(int) divide(int a, int b) {
    if b == 0 {
        raise "cannot divide by zero";
    }
    return a / b;
}

void main() {
    int result = divide(10, 2) else error {
        print(error);
        return;
    }
    print(result);

    int bad = divide(10, 0) else error {
        print(error);
        return;
    }
    print(bad);
}
