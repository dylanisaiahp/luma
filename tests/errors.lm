void main() {
    # 1. println instead of print
    println("Hello");

    # 2. % for modulus
    int remainder = 17 % 5;

    # 3. // comment
    // This is a comment

    # 4. function keyword
    function add(int x, int y) {
        return x + y;
    }

    # 5. elif without space
    int x = 7;
    if x > 10 {
        print("big");
    } elif x > 5 {
        print("medium");
    }

    # 6. == for assignment
    int x == 5;

    # 7. null/nil
    string name = null;

    # 8. ++ operator
    int counter = 0;
    counter++;

    # 9. String type with capital S
    String message = "hello";

    print("Done!");
}
