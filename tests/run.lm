# tests/run.lm
void main() {
    # Basic command
    string result = run("echo hello") else e {
        print("failed: &{e}");
        return;
    }
    print(result);

    # Multi-arg command
    string files = run("ls", "tests/") else e {
        print("failed: &{e}");
        return;
    }
    print(files);

    # Error handling — should catch the error, then continue
    string _bad = run("cat nonexistent_file.txt") else e {
        print("caught error: &{e}");
    }

    print("starting list match tests");

    # --- list match tests ---
    list(string) flags = ("verbose", "time");
    match flags {
        ("verbose", "v"):
            print("verbose on");
        ("time", "t"):
            print("time on");
        _:
            print("unknown flag");
    }

    list(string) mixed = ("verbose", "foo", "bar");
    match mixed {
        ("verbose", "v"):
            print("verbose on");
        _:
            print("unknown");
    }

    list(string) no_flags = ();
    match no_flags {
        ("verbose", "v"):
            print("verbose on");
        _:
            print("nothing passed");
    }
}
