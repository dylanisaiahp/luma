maybe(string) get_user(bool logged_in) {
    if logged_in {
        return "Dylan";
    }
    return empty;
}

void main() {
    maybe(string) name = get_user(true);
    maybe(string) nobody = get_user(false);

    print(name.exists());
    print(nobody.exists());

    string greeting = name.or("Guest").upper();
    print(greeting);

    print(nobody.or("Guest"));

    maybe(int) age = empty;
    print(age.or(0));

    maybe(string) chained = "  hello  ";
    print(chained.trim().upper());
}
